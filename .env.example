# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WeChat Push Configuration
# Option 1: WeChatFerry (requires running WeChatFerry service)
WCF_HOST=127.0.0.1
WCF_PORT=8080

# Option 2: ServerChan (serverchan.ftqq.com)
SERVERCHAN_SENDKEY=your_sendkey_here

# Option 3: GeweBot
GEWE_BOT_URL=http://localhost:9500
GEWE_BOT_TOKEN=your_bot_token

# Alert Email (optional backup notification)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=your_alert_email@gmail.com

# System Settings
LOG_LEVEL=INFO
DATABASE_PATH=./data/stock_news.db
REDIS_URL=redis://localhost:6379/0
